{
  "name": "@opendirectory.dev/skills",
  "version": "0.1.72",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opendirectory": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "registry.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node -e \"const fs=require('fs');fs.rmSync('./dist',{recursive:true,force:true});fs.rmSync('./skills',{recursive:true,force:true});fs.cpSync('../../skills','./skills',{recursive:true})\" && tsc",
    "dev": "tsc -w",
    "prepack": "pnpm run build",
    "test:e2e": "pnpm run build && vitest run src/e2e.test.ts"
  },
  "dependencies": {
    "@clack/core": "^1.3.1",
    "@clack/prompts": "^1.4.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "gradient-string": "^2.0.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.5",
    "@types/ora": "^3.2.0",
    "typescript": "^5.0.0",
    "vite": "^7.1.12",
    "vitest": "^4.1.7"
  }
}
